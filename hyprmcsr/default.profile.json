{
  "onStart": [
    "obs",
    "hyprmcsr run-jar ninjabrain-bot",
    "killall -SIGUSR1 waybar",
    "~/.config/hidconsole -i C547 1101073D001C2000000000000000000000000000"
  ],
  "onDestroy": [
    "hyprctl dispatch closewindow class:ninjabrainbot-Main",
    "killall -SIGUSR1 waybar",
    "hyprctl keyword input:sensitivity 0",
    "~/.config/hidconsole -i C547 1101073D00038400000000000000000000000000",
    "hyprctl dispatch closewindow match:title Minecraft\\*\\s1\\.16\\.1+\\s-\\sMCSR\\sRanked"
  ],
  "onToggleBinds": [],
  "binds": {
    "toggleBinds": ",HOME",
    "modeSwitch": {
      "tall": ",less",
      "boat-eye": ",bar",
      "planar-abuse": ",l"
    },
    "custom": {}
  },
  "modeSwitch": {
    "default": {
      "size": "fullscreen",
      "sensitivity": "-0.875",
      "onExit": [],
      "onEnter": []
    },
    "modes": {
      "normal": {
        "size": "fullscreen"
      },
      "tall": {
        "size": "400x1440"
      },
      "boat-eye": {
        "size": "400x16384",
        "onEnter": [
          "~/.config/hidconsole -i C547 1101073D00006400000000000000000000000000"
        ],
        "onExit": [
          "~/.config/hidconsole -i C547 1101073D001C2000000000000000000000000000"
        ]
      },
      "planar-abuse": {
        "size": "2560x400"
      }
    }
  },
  "minecraft": {
    "onStart": [],
    "windowTitleRegex": "MCSR",
    "prismLauncher": {
      "autoReplaceWrapperCommand": {
        "enabled": true,
        "innerCommand": "obs-gamecapture"
      },
      "instanceId": "Ranked",
      "autoLaunch": true,
      "flatpak": false
    },
    "observeState": {
      "enabled": true
    }
  },
  "autoDestroyOnExit": true,
  "requireSudo": true
}
